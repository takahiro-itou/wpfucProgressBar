
<UserControl x:Class="WpfControl.Utils.ProgressControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfControl"
    mc:Ignorable="d"
    d:DesignHeight="104" d:DesignWidth="400"
>

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="Bool2Visible" />
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ProgressBar
      Margin="8,8,8,8" Height="32"
      Maximum="100" Minimum="0"
      Value="{Binding ProgressValue}"
    />
    <TextBlock
      Margin="8,12,8,12"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Text="{Binding ProgressValue, StringFormat=' {0} %'}"
    />

    <StackPanel Grid.Row="1"
      Orientation="Horizontal"
      HorizontalAlignment="Center"
    >
      <Button Content="Cancel" Width="64" Margin="8,8,8,8"
        Visibility="{Binding IsCancelable, Converter={StaticResource Bool2Visible}, Mode=OneWay}"
      />
      <Button Content="Pause"  Width="64" Margin="8,8,8,8"
        Visibility="{Binding IsPausable, Converter={StaticResource Bool2Visible}, Mode=OneWay}"
        Command="{Binding PauseCommand}"
      />
      <Button Content="Resume" Width="64" Margin="8,8,8,8"
        Visibility="{Binding IsPausable, Converter={StaticResource Bool2Visible}, Mode=OneWay}"
        Command="{Binding ResumeCommand}"
       />
    </StackPanel>

  </Grid>

</UserControl>
